{
  "name": "kutub",
  "version": "1.0.0",
  "description": "Static Arabic books library built with Eleventy and Pagefind.",
  "scripts": {
    "import:turath": "tsx scripts/import-turath-book.ts",
    "sync-content": "tsx scripts/generate-canonical-chapters.ts",
    "client": "tsc -p tsconfig.client.json",
    "client:watch": "tsc -p tsconfig.client.json --watch",
    "css": "tailwindcss -i ./src/styles/global.css -o ./site/assets/site.css --minify",
    "css:watch": "tailwindcss -i ./src/styles/global.css -o ./site/assets/site.css --watch",
    "eleventy": "node --import tsx ./node_modules/@11ty/eleventy/cmd.cjs --config=eleventy.config.ts",
    "eleventy:serve": "node --import tsx ./node_modules/@11ty/eleventy/cmd.cjs --config=eleventy.config.ts --serve --port=4321",
    "dev": "npm run sync-content && npm run client && npm run css && run-p client:watch css:watch eleventy:serve",
    "build": "npm run sync-content && npm run client && npm run css && npm run eleventy && pagefind --site dist",
    "preview": "http-server dist -a 127.0.0.1 -p 4173 -c-1",
    "preview:e2e": "npm run build && npm run preview",
    "lint": "oxlint . --deny-warnings",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "eleventy",
    "pagefind",
    "arabic",
    "books"
  ],
  "type": "module",
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@tailwindcss/cli": "^4.2.2",
    "http-server": "^14.1.1",
    "markdown-it": "^14.1.1",
    "npm-run-all": "^4.1.5",
    "pagefind": "^1.5.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "oxlint": "^1.60.0",
    "typescript": "^5.9.3"
  }
}
