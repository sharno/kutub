{
  "name": "kutub",
  "version": "1.0.0",
  "description": "Static Arabic books library built with Astro and Pagefind.",
  "scripts": {
    "import:turath": "tsx scripts/import-turath-book.ts",
    "sync-content": "tsx scripts/generate-canonical-chapters.ts",
    "dev": "npm run sync-content && astro dev",
    "build": "npm run sync-content && astro build && pagefind --site dist",
    "preview": "npm run sync-content && astro preview",
    "preview:e2e": "npm run build && astro preview --host 127.0.0.1 --port 4173",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "astro",
    "pagefind",
    "arabic",
    "books"
  ],
  "type": "module",
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.6",
    "pagefind": "^1.5.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0"
  }
}
