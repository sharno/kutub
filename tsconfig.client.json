{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "ES2022"],
    "strict": true,
    "noEmitOnError": true,
    "outDir": "site/assets",
    "rootDir": "site/client",
    "skipLibCheck": true
  },
  "include": ["site/client/**/*.ts"]
}
