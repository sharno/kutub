---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  dir?: "rtl" | "ltr";
}

const {
  title,
  description = "مكتبة عربية ثابتة وسريعة للكتب المكتوبة بصيغة Markdown.",
  dir = "rtl",
} = Astro.props;
---

<!doctype html>
<html lang="ar" dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=IBM+Plex+Sans+Arabic:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="text-ink">
    <div class="min-h-screen px-4 py-8 md:px-5 md:pb-12">
      <div class="mx-auto max-w-[76rem] overflow-hidden rounded-[32px] border border-[rgba(97,65,35,0.12)] bg-[rgba(255,252,247,0.72)] shadow-[0_20px_60px_rgba(65,42,20,0.12)] backdrop-blur-[18px]">
        <header
          class="flex flex-col items-start justify-between gap-4 border-b border-[rgba(73,53,34,0.14)] px-4 py-5 md:flex-row md:items-center md:px-6"
          data-pagefind-ignore="all"
        >
          <div class="grid gap-1">
            <a href="/" class="font-display text-[clamp(1.5rem,3vw,2.2rem)] font-bold no-underline">
              كُتُب
            </a>
            <small class="text-sm text-muted">مكتبة عربية ثابتة قابلة للتوسعة والبحث</small>
          </div>

          <nav class="flex flex-wrap gap-3" aria-label="التنقل الرئيسي">
            <a
              href="/"
              class="rounded-full border border-[rgba(73,53,34,0.14)] bg-white/45 px-4 py-2 no-underline transition hover:bg-white/70"
            >
              الرئيسية
            </a>
            <a
              href="/search"
              class="rounded-full border border-[rgba(73,53,34,0.14)] bg-white/45 px-4 py-2 no-underline transition hover:bg-white/70"
            >
              البحث
            </a>
          </nav>
        </header>

        <main class="p-4 md:p-6">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
