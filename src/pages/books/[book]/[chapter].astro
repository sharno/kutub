---
import { render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getBookBySlug, getBookDownloadUrl, getBooks, getChapterUrl, getChaptersForBook } from "../../../lib/content";

export async function getStaticPaths() {
  const books = await getBooks();
  const entries = await Promise.all(
    books.map(async (book) => {
      const chapters = await getChaptersForBook(book.data.slug);
      return chapters.map((chapter) => ({
        params: {
          book: book.data.slug,
          chapter: chapter.data.slug,
        },
      }));
    }),
  );

  return entries.flat();
}

const bookSlug = Astro.params.book;
const chapterSlug = Astro.params.chapter;

if (!bookSlug || !chapterSlug) {
  throw new Error("Missing route params.");
}

const book = await getBookBySlug(bookSlug);

if (!book) {
  return Astro.redirect("/");
}

const chapters = await getChaptersForBook(bookSlug);
const chapter = chapters.find((entry) => entry.data.slug === chapterSlug);

if (!chapter) {
  return Astro.redirect(`/books/${bookSlug}`);
}

const currentIndex = chapters.findIndex((entry) => entry.id === chapter.id);
const previousChapter = currentIndex > 0 ? chapters[currentIndex - 1] : undefined;
const nextChapter = currentIndex >= 0 ? chapters[currentIndex + 1] : undefined;

const { Content } = await render(chapter);
---

<BaseLayout
  title={`${chapter.data.title} | ${book.data.title}`}
  description={chapter.data.excerpt ?? book.data.description}
  dir={book.data.direction}
>
  <div class="grid gap-4 lg:grid-cols-[19rem_minmax(0,1fr)] lg:gap-0">
    <aside class="grid gap-4 lg:border-s lg:border-[rgba(73,53,34,0.12)] lg:bg-[#f3efe6]" data-pagefind-ignore="all">
      <details class="rounded-[20px] border border-[rgba(73,53,34,0.12)] bg-[#f8f5ee] p-4 lg:hidden" open>
        <summary class="cursor-pointer list-none font-display text-xl leading-tight text-ink">
          فصول الكتاب
        </summary>
        <div class="mt-4 grid gap-1.5">
          {chapters.map((entry) => {
            const isActive = entry.id === chapter.id;
            return (
              <a
                href={getChapterUrl(entry)}
                aria-current={isActive ? "page" : undefined}
                class:list={[
                  "rounded-xl px-3 py-2 text-sm no-underline transition",
                  isActive
                    ? "bg-[rgba(142,75,34,0.12)] text-bronze-strong"
                    : "text-muted hover:bg-[rgba(142,75,34,0.07)] hover:text-bronze-strong",
                ]}
              >
                <span class="block text-xs uppercase tracking-[0.08em]">الفصل {entry.data.order}</span>
                <span class:list={["mt-1 block font-display text-lg leading-tight", isActive ? "text-bronze-strong" : "text-ink"]}>
                  {entry.data.title}
                </span>
              </a>
            );
          })}
        </div>
      </details>

      <nav
        id="chapter-sidebar"
        data-scroll-key={book.data.slug}
        class="hidden max-h-[calc(100vh-2rem)] overflow-y-auto px-4 py-6 lg:grid lg:sticky lg:top-0"
        aria-label="فصول الكتاب"
      >
        <div class="grid gap-1 border-b border-[rgba(73,53,34,0.12)] pb-4">
          <div class="eyebrow">الفهرس</div>
          <a href={`/books/${book.data.slug}`} class="font-display text-2xl leading-tight text-ink no-underline">
            {book.data.title}
          </a>
          <p class="text-sm text-muted">{book.data.author}</p>
          <p class="text-xs text-muted">{chapters.length} فصل</p>
        </div>

        <div class="mt-4 grid gap-1.5">
          {chapters.map((entry) => {
            const isActive = entry.id === chapter.id;
            return (
              <a
                href={getChapterUrl(entry)}
                aria-current={isActive ? "page" : undefined}
                class:list={[
                  "rounded-xl px-3 py-2 no-underline transition",
                  isActive
                    ? "bg-[rgba(142,75,34,0.12)] text-bronze-strong"
                    : "text-muted hover:bg-[rgba(142,75,34,0.07)] hover:text-bronze-strong",
                ]}
              >
                <span class="block text-xs uppercase tracking-[0.08em]">الفصل {entry.data.order}</span>
                <span class:list={["mt-1 block font-display text-lg leading-tight", isActive ? "text-bronze-strong" : "text-ink"]}>
                  {entry.data.title}
                </span>
              </a>
            );
          })}
        </div>
      </nav>
    </aside>

    <article class="grid gap-6 px-0 lg:px-10 lg:py-8">
      <header class="grid gap-4 border-b border-[rgba(73,53,34,0.12)] pb-6">
        <div class="eyebrow">قراءة الكتاب</div>
        <div class="meta-row text-sm">
          <a class="text-bronze-strong" href={`/books/${book.data.slug}`}>
            {book.data.title}
          </a>
          <span class="text-muted">المؤلف: {book.data.author}</span>
        </div>
        <h1 class="font-display text-[clamp(2rem,4.8vw,3.2rem)] leading-tight">{chapter.data.title}</h1>
        {chapter.data.excerpt && <p>{chapter.data.excerpt}</p>}

        <div class="flex flex-wrap gap-2">
          <span class="pill" data-pagefind-filter={`book:${book.data.title}`}>{book.data.title}</span>
          <span class="pill" data-pagefind-filter={`author:${book.data.author}`}>{book.data.author}</span>
          <a class="pill" href={getBookDownloadUrl(book)} download={`${book.data.slug}.md`}>
            تنزيل Markdown
          </a>
        </div>
      </header>

      <div class="grid gap-4" data-pagefind-body>
        <div class="meta-row border-b border-[rgba(73,53,34,0.1)] pb-3 text-sm text-muted">
          <span data-pagefind-meta="book">{book.data.title}</span>
          <span data-pagefind-meta="author">{book.data.author}</span>
          <span data-pagefind-meta="chapter">{chapter.data.title}</span>
        </div>

        <div class="reader-prose max-w-[48rem]">
          <Content />
        </div>
      </div>

      <nav
        class="meta-row justify-between border-t border-[rgba(73,53,34,0.12)] pt-6"
        aria-label="التنقل بين الفصول"
        data-pagefind-ignore="all"
      >
        {previousChapter ? (
          <a href={getChapterUrl(previousChapter)} class="text-bronze-strong no-underline">
            ← {previousChapter.data.title}
          </a>
        ) : (
          <span class="text-muted">بداية الكتاب</span>
        )}

        {nextChapter ? (
          <a href={getChapterUrl(nextChapter)} class="text-bronze-strong no-underline">
            {nextChapter.data.title} →
          </a>
        ) : (
          <span class="text-muted">نهاية الفصول الحالية</span>
        )}
      </nav>
    </article>
  </div>

  <script>
    const sidebar = document.getElementById("chapter-sidebar");
    if (sidebar) {
      const storageKey = `chapter-sidebar-scroll:${sidebar.dataset.scrollKey ?? ""}`;
      const savedScrollTop = sessionStorage.getItem(storageKey);
      if (savedScrollTop !== null) {
        sidebar.scrollTop = Number(savedScrollTop);
      }

      const persistScroll = () => {
        sessionStorage.setItem(storageKey, String(sidebar.scrollTop));
      };

      sidebar.addEventListener("scroll", persistScroll, { passive: true });
      window.addEventListener("pagehide", persistScroll, { passive: true });

      const activeLink = sidebar.querySelector('[aria-current="page"]');
      if (activeLink && savedScrollTop === null) {
        activeLink.scrollIntoView({ block: "nearest" });
      }
    }
  </script>
</BaseLayout>
