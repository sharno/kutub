---
import type { BookEntry } from "../lib/content";
import { getBookDownloadUrl, getBookUrl } from "../lib/content";

interface Props {
  book: BookEntry;
}

const { book } = Astro.props;
---

<article class="grid gap-2 rounded-[12px] border border-[rgba(73,53,34,0.14)] bg-white p-3">
  <h3 class="font-display text-[1.35rem] leading-tight">
    <a href={getBookUrl(book)} class="text-bronze-strong">
      {book.data.title}
    </a>
  </h3>
  <p class="text-muted">المؤلف: {book.data.author}</p>
  <p class="text-sm">{book.data.description}</p>

  <div class="flex flex-wrap gap-1.5">
    {book.data.tags.map((tag) => <span class="pill">{tag}</span>)}
  </div>

  <div class="meta-row pt-1 text-sm" data-pagefind-ignore="all">
    <a href={getBookUrl(book)} class="pill">
      قراءة
    </a>
    <a href={getBookDownloadUrl(book)} class="pill" download={`${book.data.slug}.md`}>
      تنزيل
    </a>
  </div>
</article>
